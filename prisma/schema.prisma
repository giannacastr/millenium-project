generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserType {
  EQUITY_TRADER
  RISK_OFFICER
  PRIME_BROKER
}

enum OrderDirection {
  BUY
  SELL
  SHORT
}

enum OrderTypeEnum {
  MARKET
  LIMIT
  VWAP
}

enum OrderStatus {
  DRAFT
  SUBMITTED
  IN_REVIEW
  RISK_APPROVED
  ACKNOWLEDGED
  PARTIALLY_FILLED
  FULLY_FILLED
  REJECTED
  CANCELLED
}

model User {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  name         String
  passwordHash String
  type         UserType
  enabled      Boolean  @default(true)
  pending      Boolean  @default(false)

  isSuper            Boolean @default(false)
  userRead           Boolean @default(false)
  userWrite          Boolean @default(false)
  orderRead          Boolean @default(false)
  orderWrite         Boolean @default(false)
  reportRead         Boolean @default(false)
  reportWrite        Boolean @default(false)

  partnerDetails Json?

  notifications Notification[]
  traderOrders  Order[] @relation("TraderOrders")
  riskReviews   Order[] @relation("RiskReviews")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model UserInvite {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  token     String   @unique
  userType  UserType
  expiresAt DateTime

  createdAt DateTime @default(now())
}

model Notification {
  id           Int       @id @default(autoincrement())
  title        String
  action       String?
  actionText   String?
  dateCreated  DateTime  @default(now())
  dateViewed   DateTime?
  isDelivered  Boolean   @default(false)
  template     String?
  payload      Json?
  userId       Int
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, dateViewed])
}

model PasswordResetToken {
  id        Int      @id @default(autoincrement())
  userId    Int
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)

  createdAt DateTime @default(now())
}

model Order {
  id       Int    @id @default(autoincrement())
  ticketKey String @unique
  title    String?

  direction   OrderDirection
  ticker      String
  quantity    Int
  orderType   OrderTypeEnum
  limitPrice  Decimal? @db.Decimal(18, 4)
  account     String
  strategy    String
  notes       String?

  status OrderStatus @default(DRAFT)

  traderId Int
  trader   User @relation("TraderOrders", fields: [traderId], references: [id])

  reviewedById Int?
  reviewer     User? @relation("RiskReviews", fields: [reviewedById], references: [id])

  riskApprovedWithConditions Boolean @default(false)

  brokerRejectReason String?
  brokerRejectCode   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  activities OrderActivity[]
  breachLogs RiskBreachLog[]

  @@index([status])
  @@index([traderId])
  @@index([createdAt])
}

model OrderActivity {
  id        Int      @id @default(autoincrement())
  orderId   Int
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  message   String
  actorName String?
  createdAt DateTime @default(now())

  @@index([orderId])
}

model RiskBreachLog {
  id           Int      @id @default(autoincrement())
  orderId      Int
  order        Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  checkType    String
  breachDetail String?
  resolution   String?
  actorUserId  Int?
  createdAt    DateTime @default(now())

  @@index([orderId])
}

model Holding {
  id        Int      @id @default(autoincrement())
  ticker    String
  shares    Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([ticker])
}

model RiskLimit {
  id                    Int      @id @default(autoincrement())
  singleNameCapPct      Float    @default(10)
  sectorCapPct          Float    @default(30)
  grossExposureCapPct   Float    @default(180)
  netExposureCapPct     Float    @default(70)
  buyingPowerUsedCapPct Float    @default(90)
  maxOrderNotional      Float    @default(5000000)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}
