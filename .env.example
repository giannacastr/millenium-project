# Copy this file to `.env` and fill in values. Never commit `.env`.

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# Example local install (default postgres user):
#   DATABASE_URL="postgresql://postgres:yourpassword@localhost:5432/millennium"
#
# Create the database once (choose one):
#   macOS/Linux (psql):  psql -U postgres -c "CREATE DATABASE millennium;"
#   Or use pgAdmin / TablePlus / etc.

DATABASE_URL="postgresql://postgres:password@localhost:5432/millennium"

# -----------------------------------------------------------------------------
# NextAuth.js (Auth.js)
# -----------------------------------------------------------------------------
# Required. Used to sign JWT sessions. Generate a strong secret:
#   openssl rand -base64 32
AUTH_SECRET="paste-output-from-openssl-here"

# URL of this app (where users open the site). No trailing slash.
# Development:
NEXTAUTH_URL="http://localhost:3000"
# Production example:
# NEXTAUTH_URL="https://your-domain.com"

# -----------------------------------------------------------------------------
# Optional
# -----------------------------------------------------------------------------
# NODE_ENV="development"
